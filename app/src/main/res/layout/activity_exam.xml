<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorHeaderBg">

    <!-- ══ TOP BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_topbar"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical">

        <!-- Logo kecil -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter"
            android:layout_marginEnd="10dp"
            android:contentDescription="Logo" />

        <!-- URL info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SESI UJIAN"
                android:textColor="#66FFFFFF"
                android:textSize="8.5sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tvSiteUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Memuat..."
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Secure badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_secure"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒 AMAN"
                android:textColor="@color/colorPrimary"
                android:textSize="9.5sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══ PROGRESS BAR ══ -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:progressTint="@color/colorPrimary"
        android:progressBackgroundTint="@color/colorHeaderDark"
        android:visibility="gone" />

    <!-- ══ WEBVIEW ══ -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ══ BOTTOM BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_bottom_bar"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <Button
            android:id="@+id/btnExit"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_exit_btn"
            android:text="Keluar dari Ujian"
            android:textColor="@color/colorDanger"
            android:textSize="12.5sp"
            android:textStyle="bold"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />
    </LinearLayout>

</LinearLayout>
