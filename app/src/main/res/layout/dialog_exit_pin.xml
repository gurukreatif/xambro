<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:padding="28dp"
    android:gravity="center_horizontal">

    <!-- Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔐"
        android:textSize="40sp"
        android:layout_marginBottom="14dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Akhiri Sesi Ujian?"
        android:textColor="@color/colorTextPrimary"
        android:textSize="19sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="6dp" />

    <!-- Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Masukkan PIN pengawas untuk mengakhiri sesi"
        android:textColor="@color/colorTextSecondary"
        android:textSize="12.5sp"
        android:gravity="center"
        android:layout_marginBottom="22dp" />

    <!-- PIN label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PIN PENGAWAS"
        android:textColor="@color/colorTextSecondary"
        android:textSize="10sp"
        android:letterSpacing="0.12"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- PIN input -->
    <EditText
        android:id="@+id/etPin"
        android:layout_width="160dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_pin_input"
        android:gravity="center"
        android:hint="• • • •"
        android:inputType="numberPassword"
        android:maxLength="8"
        android:textColor="@color/colorTextPrimary"
        android:textColorHint="@color/colorTextHint"
        android:textSize="22sp"
        android:letterSpacing="0.3"
        android:layout_marginBottom="22dp" />

    <!-- Confirm button -->
    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_btn_confirm"
        android:text="Konfirmasi Keluar"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Cancel button -->
    <Button
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_btn_cancel"
        android:text="Lanjutkan Ujian"
        android:textColor="@color/colorTextSecondary"
        android:textSize="13sp" />

</LinearLayout>
