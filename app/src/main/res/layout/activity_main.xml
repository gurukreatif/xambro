<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- ══ HEADER ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="28dp">

        <!-- Logo -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter"
            android:contentDescription="Logo" />

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/app_title"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/app_description"
            android:textColor="#99FFFFFF"
            android:textSize="12.5sp"
            android:gravity="center" />

        <!-- Secure badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_badge_secure"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡  SECURE EXAM MODE"
                android:textColor="@color/colorPrimary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══ BODY ══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <!-- URL Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="18dp"
                android:elevation="2dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="URL UJIAN"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Input row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etUrl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:hint="https://ujian.sekolah.id/..."
                        android:inputType="textUri"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextPrimary"
                        android:textColorHint="@color/colorTextHint"
                        android:fontFamily="monospace"
                        android:imeOptions="actionGo"
                        android:singleLine="true" />

                    <!-- Scanner button -->
                    <LinearLayout
                        android:id="@+id/btnScanQr"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_button_scan"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⬚"
                            android:textColor="@color/colorPrimary"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/colorDivider" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="atau scan QR Code pengawas"
                        android:textColor="@color/colorTextHint"
                        android:textSize="11sp" />
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/colorDivider" />
                </LinearLayout>

                <!-- Start button -->
                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Mulai Ujian"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Security feature card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="18dp"
                android:elevation="2dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FITUR KEAMANAN"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Feature rows -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="38dp"
                    android:background="@drawable/bg_feature_row" android:gravity="center_vertical"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="20dp" android:layout_height="20dp"
                        android:background="@drawable/bg_check" android:gravity="center"
                        android:text="✓" android:textColor="@color/white" android:textSize="10sp"
                        android:textStyle="bold" android:layout_marginEnd="10dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tombol Back &amp; Home diblokir"
                        android:textColor="@color/colorTextPrimary" android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="38dp"
                    android:background="@drawable/bg_feature_row" android:gravity="center_vertical"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="20dp" android:layout_height="20dp"
                        android:background="@drawable/bg_check" android:gravity="center"
                        android:text="✓" android:textColor="@color/white" android:textSize="10sp"
                        android:textStyle="bold" android:layout_marginEnd="10dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Fullscreen tanpa gangguan"
                        android:textColor="@color/colorTextPrimary" android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="38dp"
                    android:background="@drawable/bg_feature_row" android:gravity="center_vertical"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="20dp" android:layout_height="20dp"
                        android:background="@drawable/bg_check" android:gravity="center"
                        android:text="✓" android:textColor="@color/white" android:textSize="10sp"
                        android:textStyle="bold" android:layout_marginEnd="10dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Keluar hanya dengan PIN pengawas"
                        android:textColor="@color/colorTextPrimary" android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="38dp"
                    android:background="@drawable/bg_feature_row" android:gravity="center_vertical"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="20dp" android:layout_height="20dp"
                        android:background="@drawable/bg_check" android:gravity="center"
                        android:text="✓" android:textColor="@color/white" android:textSize="10sp"
                        android:textStyle="bold" android:layout_marginEnd="10dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Scan QR Code URL ujian"
                        android:textColor="@color/colorTextPrimary" android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="38dp"
                    android:background="@drawable/bg_feature_row" android:gravity="center_vertical"
                    android:paddingStart="12dp" android:paddingEnd="12dp">
                    <TextView android:layout_width="20dp" android:layout_height="20dp"
                        android:background="@drawable/bg_check" android:gravity="center"
                        android:text="✓" android:textColor="@color/white" android:textSize="10sp"
                        android:textStyle="bold" android:layout_marginEnd="10dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Screenshot &amp; perekaman diblokir"
                        android:textColor="@color/colorTextPrimary" android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ══ COPYRIGHT BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@drawable/bg_copyright_bar"
        android:gravity="center">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 Emes EduTech"
            android:textColor="@color/colorTextHint"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
